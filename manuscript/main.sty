%%% --- amsart title/section formatting patches ---
\makeatletter
\patchcmd{\@settitle}{\uppercasenonmath\@title}{\large}{}{}
\patchcmd{\@setauthors}{\MakeUppercase}{\vspace{-1em}\normalsize}{}{}
\patchcmd{\section}{\scshape}{\bfseries}{}{}
\makeatother

