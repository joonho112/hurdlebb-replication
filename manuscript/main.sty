% main.sty — Custom style package for IT Enrollment manuscript
% Adapted from DPprior arXiv preprint (Lee et al., 2025)
% JRSS-A: "The Poverty Reversal in Infant/Toddler Childcare"

%%% --- Encoding and fonts ---
\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage{amsfonts}
\usepackage{amssymb}
\usepackage{amsmath}
\usepackage{amsthm}
\usepackage{bbm}
\usepackage{mathrsfs}
\usepackage{bm}
\usepackage{textcomp}
\usepackage{upquote}

%%% --- Graphics and layout ---
\usepackage{tikz}
\usepackage{graphicx}
\usepackage{float}
\usepackage{mathtools}
\usepackage{mdframed}
\usepackage{xcolor}
\RequirePackage{thm-restate}

%%% --- Lists, algorithms, geometry ---
\usepackage{enumitem}
\usepackage{algorithm}
\usepackage[noend]{algpseudocode}
\usepackage[margin=1in]{geometry}
\usepackage{subcaption}

%%% --- Hyperlinks and cross-references ---
\usepackage{hyperref}
\hypersetup{
    colorlinks=true,
    linkcolor=blue,
    filecolor=magenta,
    urlcolor=cyan,
    citecolor=blue
}
\RequirePackage[capitalise, nameinlink, noabbrev]{cleveref}

%%% --- Theorem environments ---
\newtheorem{lemma}{Lemma}

\newtheoremstyle{theorem}
    {3pt}{3pt}{\slshape}{}{\bfseries}{.}{.5em}{}

\theoremstyle{definition}
\newtheorem{example}{Example}
\newtheorem{remark}{Remark}
\newtheorem{definition}{Definition}

\theoremstyle{theorem}
\newtheorem{theorem}{Theorem}
\newtheorem{corollary}{Corollary}
\newtheorem{proposition}{Proposition}
\newtheorem{conjecture}{Conjecture}
\newtheorem{as}{Assumption}

%%% --- General math commands ---
\newcommand{\bDelta}{\mathbf{\Delta}}
\newcommand{\Prob}{\mathbb{P}}
\newcommand{\E}{\mathbb{E}}
\newcommand{\e}{\epsilon}
\newcommand{\bb}[1]{\mathbb{#1}}
\newcommand{\bR}{\mathbb{R}}
\newcommand{\R}{\mathbb{R}}
\newcommand{\cl}[1]{\mathcal{#1}}
\renewcommand{\sf}[1]{\textsf{#1}}
\newcommand{\set}[1]{\left\lbrace #1 \right\rbrace}

%%% --- Math operators ---
\DeclareMathOperator*{\Cov}{Cov}
\DeclareMathOperator*{\Corr}{Corr}
\DeclareMathOperator*{\argmax}{argmax}
\DeclareMathOperator*{\argmin}{argmin}
\DeclareMathOperator*{\Var}{Var}
\newcommand{\var}{\operatorname{Var}}
\DeclareMathOperator{\logit}{logit}
\DeclareMathOperator{\expit}{expit}
\DeclareMathOperator{\diag}{diag}
\DeclareMathOperator{\tr}{tr}
\DeclareMathOperator{\vech}{vech}
\DeclareMathOperator{\elpd}{elpd}

%%% --- Independence symbol ---
\DeclareSymbolFont{symbolsC}{U}{txsyc}{m}{n}
\DeclareMathSymbol{\indep}{\mathrel}{symbolsC}{121}

